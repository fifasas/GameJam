[sub_resource type="GDScript" id="GDScript_yarnboss"]
script/source = "extends CharacterBody2D

const SPEED := 400.0
const CONTACT_DAMAGE := 15
const DAMAGE_INTERVAL := 1.0
const HIT_FLASH_DURATION := 0.2
const HIT_FLASH_COLOR := Color(1.0, 0.35, 0.35, 1.0)

@export_range(1, 9999, 1) var max_hp: int = 20
@export_range(0, 9999, 1) var current_hp: int = 20

var tracked_body: Node2D = null
var tracked_damage_target: Node = null
var hit_flash_id := 0

@onready var animated_sprite_2d: AnimatedSprite2D = $AnimatedSprite2D
@onready var damage_timer: Timer = $DamageTimer

func _ready() -> void:
	current_hp = clamp(current_hp, 0, max_hp)
	velocity = Vector2(1, -1).normalized() * SPEED
	collision_mask = 0
	set_collision_mask_value(1, true)
	set_collision_mask_value(2, true)

func _physics_process(delta: float) -> void:
	var collision := move_and_collide(velocity * delta)
	if collision:
		velocity = velocity.bounce(collision.get_normal())
		move_and_collide(velocity * delta)
		velocity = velocity.normalized() * SPEED

func _on_damage_area_body_entered(body: Node2D) -> void:
	if not _is_player_body(body):
		return

	tracked_body = body
	tracked_damage_target = _find_damage_target(body)
	if tracked_damage_target == null:
		return

	_apply_contact_damage()
	damage_timer.start(DAMAGE_INTERVAL)

func _on_damage_area_body_exited(body: Node2D) -> void:
	if body != tracked_body:
		return

	_clear_damage_tracking()

func _on_damage_timer_timeout() -> void:
	if tracked_body == null or not is_instance_valid(tracked_body):
		_clear_damage_tracking()
		return

	if tracked_damage_target == null or not is_instance_valid(tracked_damage_target):
		tracked_damage_target = _find_damage_target(tracked_body)
		if tracked_damage_target == null:
			_clear_damage_tracking()
			return

	_apply_contact_damage()

func take_damage(amount: int) -> void:
	if amount <= 0 or current_hp <= 0:
		return

	current_hp = max(current_hp - amount, 0)
	_flash_hit()
	if current_hp == 0:
		queue_free()

func _apply_contact_damage() -> void:
	if tracked_damage_target.has_method(\"damage\"):
		tracked_damage_target.damage(CONTACT_DAMAGE)
		return

	if tracked_damage_target.has_method(\"set_health\"):
		tracked_damage_target.set_health(tracked_damage_target.current_hp - CONTACT_DAMAGE)

func _clear_damage_tracking() -> void:
	tracked_body = null
	tracked_damage_target = null
	damage_timer.stop()

func _is_player_body(body: Node2D) -> bool:
	if body.is_in_group(\"player\"):
		return true
	return body.name == \"CharacterBody2D\"

func _find_damage_target(body: Node2D) -> Node:
	if body.has_method(\"damage\") or body.has_method(\"set_health\"):
		return body

	var parent := body.get_parent()
	if parent != null and (parent.has_method(\"damage\") or parent.has_method(\"set_health\")):
		return parent

	var current_scene := get_tree().current_scene
	if current_scene == null:
		return null

	var healthbar := current_scene.find_child(\"Healthbar\", true, false)
	if healthbar == null:
		healthbar = current_scene.find_child(\"healthbar\", true, false)
	return healthbar

func _flash_hit() -> void:
	hit_flash_id += 1
	var flash_id := hit_flash_id
	animated_sprite_2d.modulate = HIT_FLASH_COLOR
	_reset_flash_after_delay(flash_id)

func _reset_flash_after_delay(flash_id: int) -> void:
	await get_tree().create_timer(HIT_FLASH_DURATION).timeout
	if flash_id != hit_flash_id or not is_instance_valid(animated_sprite_2d):
		return
	animated_sprite_2d.modulate = Color(1.0, 1.0, 1.0, 1.0)
"

