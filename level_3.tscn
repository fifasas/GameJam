[sub_resource type="GDScript" id="GDScript_level_3"]
script/source = "extends Node2D

const HEALING_SCENE := preload(\"res://healing.tscn\")
const END_SCREEN_PATH := \"res://EndScreen.tscn\"
const DEATH_SCREEN_PATH := \"res://DeathScreen.tscn\"
const DEATH_SCREEN_PENDING_KEY := &\"show_death_screen_after_reload\"
const HEALING_SLOT_XS := [760.0, 1120.0, 1480.0, 1840.0, 2200.0]
const HEALING_GROUND_Y := 889.0
const MAX_HEALING_SPAWNS := 2
const HEALING_X_JITTER := 55.0
const HEALING_RESPAWN_DELAY_MIN := 8.0
const HEALING_RESPAWN_DELAY_MAX := 13.0

var boss_music_started := false
var active_healing_slots := {}
var pending_healing_respawns := 0
var rng := RandomNumberGenerator.new()

@onready var log_bridge: Node2D = $Log
@onready var bridge_collision: CollisionShape2D = $Log/BridgeBody/CollisionShape2D
@onready var birds_ambience: AudioStreamPlayer = $BirdsAmbience
@onready var boss_music_1: AudioStreamPlayer = $BossMusic1
@onready var boss_music_2: AudioStreamPlayer = $BossMusic2
@onready var river_ambience: AudioStreamPlayer2D = $RiverAmbience
@onready var healing_spawns: Node2D = $HealingSpawns
@onready var healthbar: Node = $HUD/Screen/CatUi/Healthbar
@onready var wolf: CharacterBody2D = $Wolf
@onready var wolf_sprite: AnimatedSprite2D = $Wolf/AnimatedSprite2D

func _ready() -> void:
\tif _consume_pending_death_screen():
\t\tcall_deferred(\"_show_death_screen\")
\t\treturn
	rng.randomize()
	_lock_wolf_until_log_drops()
	_spawn_random_healing()
\tif healthbar != null and healthbar.has_signal(\"health_depleted\"):
\t\thealthbar.connect(\"health_depleted\", Callable(self, \"_on_health_depleted\"), CONNECT_ONE_SHOT)
	if wolf != null and wolf.has_signal(\"boss_defeated\"):
		wolf.connect(\"boss_defeated\", Callable(self, \"_on_wolf_boss_defeated\"), CONNECT_ONE_SHOT)

func _process(_delta: float) -> void:
	if boss_music_started:
		return
	if not bridge_collision.disabled and _has_log_fallen():
		_start_boss_music()

func _has_log_fallen() -> bool:
	var has_fallen_value: Variant = log_bridge.get(\"has_fallen\")
	if has_fallen_value is bool:
		return has_fallen_value
	return false

func _start_boss_music() -> void:
	boss_music_started = true
	_release_wolf()
	birds_ambience.stop()
	boss_music_1.play()

func _on_boss_music_1_finished() -> void:
	if boss_music_started:
		boss_music_2.play()

func _on_health_depleted() -> void:
\tget_tree().set_meta(DEATH_SCREEN_PENDING_KEY, true)

func _consume_pending_death_screen() -> bool:
\tif not get_tree().has_meta(DEATH_SCREEN_PENDING_KEY):
\t\treturn false
\tvar should_show: bool = bool(get_tree().get_meta(DEATH_SCREEN_PENDING_KEY))
\tget_tree().remove_meta(DEATH_SCREEN_PENDING_KEY)
\treturn should_show

func _show_death_screen() -> void:
\tget_tree().change_scene_to_file(DEATH_SCREEN_PATH)

func _on_river_ambience_finished() -> void:
	if is_instance_valid(river_ambience):
		river_ambience.play()

func _on_wolf_boss_defeated() -> void:
	call_deferred(\"_show_end_screen\")

func _show_end_screen() -> void:
	get_tree().change_scene_to_file(END_SCREEN_PATH)

func _lock_wolf_until_log_drops() -> void:
	if wolf == null:
		return
	wolf.velocity = Vector2.ZERO
	wolf.set_physics_process(false)
	if is_instance_valid(wolf_sprite):
		wolf_sprite.play(&\"idle\")

func _release_wolf() -> void:
	if wolf == null:
		return
	wolf.set_physics_process(true)

func _spawn_random_healing() -> void:
	var initial_spawn_count: int = min(MAX_HEALING_SPAWNS, HEALING_SLOT_XS.size())
	for _i in range(initial_spawn_count):
		if not _spawn_healing_pickup():
			break

func _spawn_healing_pickup() -> bool:
	var available_slot_indices: Array = []
	for i in range(HEALING_SLOT_XS.size()):
		if not active_healing_slots.has(i):
			available_slot_indices.append(i)
	if available_slot_indices.is_empty():
		return false

	available_slot_indices.shuffle()
	var slot_index: int = int(available_slot_indices[0])
	var healing_pickup: Node2D = HEALING_SCENE.instantiate() as Node2D
	var spawn_x: float = float(HEALING_SLOT_XS[slot_index]) + rng.randf_range(-HEALING_X_JITTER, HEALING_X_JITTER)
	healing_pickup.position = Vector2(spawn_x, HEALING_GROUND_Y)
	active_healing_slots[slot_index] = healing_pickup
	healing_spawns.add_child(healing_pickup)
	if healing_pickup.has_signal(\"collected\"):
		healing_pickup.connect(\"collected\", Callable(self, \"_on_healing_collected\").bind(slot_index), CONNECT_ONE_SHOT)
	return true

func _on_healing_collected(slot_index: int) -> void:
	active_healing_slots.erase(slot_index)
	_schedule_healing_respawn()

func _schedule_healing_respawn() -> void:
	if active_healing_slots.size() + pending_healing_respawns >= MAX_HEALING_SPAWNS:
		return
	pending_healing_respawns += 1
	call_deferred(\"_respawn_healing_after_delay\")

func _respawn_healing_after_delay() -> void:
	await get_tree().create_timer(rng.randf_range(HEALING_RESPAWN_DELAY_MIN, HEALING_RESPAWN_DELAY_MAX)).timeout
	pending_healing_respawns = max(pending_healing_respawns - 1, 0)
	if not is_inside_tree():
		return
	if active_healing_slots.size() < MAX_HEALING_SPAWNS:
		_spawn_healing_pickup()
"

