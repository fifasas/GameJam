[sub_resource type="GDScript" id="GDScript_level_3"]
script/source = "extends Node2D

var boss_music_started := false

@onready var log_bridge: Node2D = $Log
@onready var bridge_collision: CollisionShape2D = $Log/BridgeBody/CollisionShape2D
@onready var birds_ambience: AudioStreamPlayer = $BirdsAmbience
@onready var boss_music_1: AudioStreamPlayer = $BossMusic1
@onready var boss_music_2: AudioStreamPlayer = $BossMusic2

func _process(_delta: float) -> void:
\tif boss_music_started:
\t\treturn
\tif not bridge_collision.disabled and _has_log_fallen():
\t\t_start_boss_music()

func _has_log_fallen() -> bool:
\tvar has_fallen_value: Variant = log_bridge.get(\"has_fallen\")
\tif has_fallen_value is bool:
\t\treturn has_fallen_value
\treturn false

func _start_boss_music() -> void:
\tboss_music_started = true
\tbirds_ambience.stop()
\tboss_music_1.play()

func _on_boss_music_1_finished() -> void:
\tif boss_music_started:
\t\tboss_music_2.play()
"

