[sub_resource type="GDScript" id="GDScript_player_char"]
script/source = "extends CharacterBody2D

const WALK_SPEED := 130.0
const SPRINT_SPEED := 220.0
const JUMP_VELOCITY := -600.0
const ATTACK_DAMAGE := 5
const ATTACK_COOLDOWN := 0.35
const DROP_THROUGH_LAYER := 2
const DROP_THROUGH_DURATION := 0.2
const HIT_FLASH_DURATION := 0.2
const HIT_FLASH_COLOR := Color(1.0, 0.35, 0.35, 1.0)

@export_range(1, 9999, 1) var max_hp: int = 100
@export_range(0, 9999, 1) var current_hp: int = 100

var facing_direction := 1
var is_attacking := false
var is_dropping_through := false
var is_sprinting := false
var healthbar: Node = null
var hit_flash_id := 0

@onready var animated_sprite_2d: AnimatedSprite2D = $AnimatedSprite2D
@onready var attack_area: Area2D = $AttackArea
@onready var attack_cooldown_timer: Timer = $AttackCooldownTimer

func _ready() -> void:
	current_hp = clamp(current_hp, 0, max_hp)
	healthbar = _find_healthbar()
	_setup_healthbar()
	_sync_healthbar()
	_update_attack_area()
	_update_animation()

func _physics_process(delta: float) -> void:
	if not is_on_floor():
		velocity += get_gravity() * delta

	if Input.is_action_just_pressed(\"jump\") and is_on_floor() and not is_attacking:
		velocity.y = JUMP_VELOCITY

	var direction := 0.0
	is_sprinting = false
	if not is_attacking:
		direction = Input.get_axis(\"left\", \"right\")
		is_sprinting = direction != 0.0 and is_on_floor() and Input.is_key_pressed(KEY_SHIFT)
		var move_speed := SPRINT_SPEED if is_sprinting else WALK_SPEED
		if direction != 0.0:
			facing_direction = 1 if direction > 0.0 else -1
			velocity.x = direction * move_speed
		else:
			velocity.x = move_toward(velocity.x, 0.0, WALK_SPEED)
	else:
		velocity.x = move_toward(velocity.x, 0.0, WALK_SPEED)

	_update_attack_area()
	_update_animation()
	move_and_slide()

func _input(event: InputEvent) -> void:
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
		_try_attack()
	elif event is InputEventKey and event.pressed and not event.echo and _is_drop_input(event):
		drop_through()

func damage(amount: int) -> void:
	if amount <= 0 or current_hp <= 0:
		return

	var previous_hp := current_hp
	current_hp = max(current_hp - amount, 0)
	if current_hp < previous_hp:
		_flash_hit()
	_sync_healthbar()
	if current_hp == 0:
		get_tree().reload_current_scene()

func heal(amount: int) -> void:
	if amount <= 0 or current_hp <= 0:
		return

	current_hp = clamp(current_hp + amount, 0, max_hp)
	_sync_healthbar()

func set_health(new_health: int) -> void:
	var previous_hp := current_hp
	current_hp = clamp(new_health, 0, max_hp)
	if current_hp < previous_hp:
		_flash_hit()
	_sync_healthbar()
	if current_hp == 0:
		get_tree().reload_current_scene()

func reset_health() -> void:
	current_hp = max_hp
	_sync_healthbar()

func is_dead() -> bool:
	return current_hp <= 0

func _try_attack() -> void:
	if is_attacking or not attack_cooldown_timer.is_stopped():
		return

	is_attacking = true
	attack_cooldown_timer.start(ATTACK_COOLDOWN)
	animated_sprite_2d.play(\"attack\")
	_update_attack_area()
	call_deferred(\"_perform_attack_hit\")

func _perform_attack_hit() -> void:
	await get_tree().physics_frame

	var hit_targets: Array[Node] = []
	for area in attack_area.get_overlapping_areas():
		var target := area.get_parent()
		if target == null or target == self or hit_targets.has(target):
			continue
		if target.has_method(\"take_damage\"):
			target.take_damage(ATTACK_DAMAGE)
			hit_targets.append(target)

	for body in attack_area.get_overlapping_bodies():
		if body == self or hit_targets.has(body):
			continue
		if body.has_method(\"take_damage\"):
			body.take_damage(ATTACK_DAMAGE)
			hit_targets.append(body)

func _update_attack_area() -> void:
	attack_area.position = Vector2(18 * facing_direction, 4)
	animated_sprite_2d.flip_h = facing_direction > 0

func _update_animation() -> void:
	if is_attacking:
		if animated_sprite_2d.animation != &\"attack\":
			animated_sprite_2d.play(\"attack\")
		return

	if not is_on_floor():
		animated_sprite_2d.play(\"jump\")
	elif abs(velocity.x) > 5.0:
		animated_sprite_2d.play(\"run\" if is_sprinting else \"walk\")
	else:
		animated_sprite_2d.play(\"Idle\")

func _on_animated_sprite_2d_animation_finished() -> void:
	if animated_sprite_2d.animation == &\"attack\":
		is_attacking = false
		_update_animation()

func drop_through() -> void:
	if is_dropping_through or not is_on_floor():
		return

	is_dropping_through = true
	set_collision_mask_value(DROP_THROUGH_LAYER, false)
	global_position.y += 2.0
	velocity.y = max(velocity.y, 50.0)
	await get_tree().create_timer(DROP_THROUGH_DURATION).timeout
	set_collision_mask_value(DROP_THROUGH_LAYER, true)
	is_dropping_through = false

func _is_drop_input(event: InputEventKey) -> bool:
	return event.is_action_pressed(\"ui_down\") or event.physical_keycode == KEY_S or event.keycode == KEY_DOWN

func _find_healthbar() -> Node:
	var current_scene := get_tree().current_scene
	if current_scene == null:
		return null

	var found_healthbar := current_scene.find_child(\"Healthbar\", true, false)
	if found_healthbar == null:
		found_healthbar = current_scene.find_child(\"healthbar\", true, false)
	return found_healthbar

func _setup_healthbar() -> void:
	if healthbar == null:
		return
	if healthbar.has_method(\"set_max_health\"):
		healthbar.set_max_health(max_hp)

func _sync_healthbar() -> void:
	if healthbar == null or not is_instance_valid(healthbar):
		healthbar = _find_healthbar()
		_setup_healthbar()
	if healthbar != null and healthbar.has_method(\"set_health\"):
		healthbar.set_health(current_hp)

func _flash_hit() -> void:
	hit_flash_id += 1
	var flash_id := hit_flash_id
	animated_sprite_2d.modulate = HIT_FLASH_COLOR
	_reset_flash_after_delay(flash_id)

func _reset_flash_after_delay(flash_id: int) -> void:
	await get_tree().create_timer(HIT_FLASH_DURATION).timeout
	if flash_id != hit_flash_id or not is_instance_valid(animated_sprite_2d):
		return
	animated_sprite_2d.modulate = Color(1.0, 1.0, 1.0, 1.0)
"

